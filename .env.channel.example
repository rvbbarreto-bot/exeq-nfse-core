# Stack canal NFSe — Opção B (copiar para .env.channel — NUNCA commitar)
# Uso: docker compose -f docker-compose.yml -f docker-compose.channel.yml --profile channel up -d

# ── n8n ─────────────────────────────────────────────────────────────────────
N8N_POSTGRES_DB=n8n_nfse
N8N_POSTGRES_USER=n8n_nfse
N8N_POSTGRES_PASSWORD=change-me-n8n-db
N8N_ENCRYPTION_KEY=change-me-32-chars-minimum-n8n-key!!
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-n8n-ui
N8N_WEBHOOK_URL=http://localhost:5680/

# ── Evolution ───────────────────────────────────────────────────────────────
EVOLUTION_POSTGRES_DB=evolution_nfse
EVOLUTION_POSTGRES_USER=evolution_nfse
EVOLUTION_POSTGRES_PASSWORD=change-me-evolution-db
EVOLUTION_API_KEY=change-me-evolution-api-key
EVOLUTION_SERVER_URL=http://localhost:8082
EVOLUTION_INSTANCE=exeq-nfse-core
EVOLUTION_IMAGE=evoapicloud/evolution-api:v2.3.7

# ── Integração Core (n8n container → API no host) ───────────────────────────
EXEQ_API_BASE_URL=http://host.docker.internal:3002
EXEQ_TENANT_SLUG=piloto-sp
EXEQ_CHANNEL_TOKEN=sandbox-channel-token-piloto

# Rede interna Docker (n8n → evolution no mesmo compose)
EVOLUTION_API_URL=http://evolution:8080

# Linha WhatsApp conectada no Evolution (referência — NÃO filtra remetentes)
CHANNEL_PAIRED_PHONE=+5511973305448
# Cliente simulado nos testes E2E
CHANNEL_E2E_PHONE=+5511973857162
# Piloto fechado (opcional): CHANNEL_ALLOWED_SENDERS=+5511973857162
