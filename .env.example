# Database (app role — RLS enforced; migrations use MIGRATION_DATABASE_URL)
DATABASE_URL=postgres://exeq_app:exeq_app_dev@localhost:55432/exeq_nfse
MIGRATION_DATABASE_URL=postgres://exeq:exeq_dev@localhost:55432/exeq_nfse

# Auth (dev only — rotate in staging/prod)
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=8h

# Secret vault (32-byte hex = 64 chars)
MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# API
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Pilot seed
SEED_ADMIN_EMAIL=admin@piloto.local
SEED_ADMIN_PASSWORD=changeme

# Redis / workers (Fase 4)
REDIS_URL=redis://localhost:6382
NF_SYNC_PROCESSING=false

# Canal WhatsApp — agrupa mensagens (segundos após a última msg; 0=desliga). Resposta async via Evolution.
CHANNEL_DEBOUNCE_SECONDS=40
EVOLUTION_SERVER_URL=http://localhost:8082
EVOLUTION_INSTANCE=exeq-nfse-core
EVOLUTION_API_KEY=

# LLM — extração de campos em linguagem natural (fallback do parser regex)
OPENAI_API_KEY=
LLM_EXTRACTION_MODEL=gpt-4o-mini
LLM_CONFIDENCE_THRESHOLD=0.50
CHANNEL_LLM_FALLBACK_ENABLED=true
LLM_TIMEOUT_MS=8000

# Focus NFe sandbox (PO 2026-06-19: única integração fiscal habologada)
FOCUS_BASE_URL=https://homologacao.focusnfe.com.br
FOCUS_MOCK=true
FOCUS_HOMOLOG_MOCK=true

# Política de roteamento fiscal — focus_only = sem Betha (AUTORIZACAO_PO_FOCUS_ONLY_HOMOLOG_2026-06-19)
NFSE_ROUTING_POLICY=focus_only

# Betha — congelado; manter false até nova autorização PO
# BETHA_ATIBAIA_ENABLED=false
# BETHA_MOCK=true

# Webhooks / cobranca (Fase 6)
WEBHOOK_SYNC_PROCESSING=false

# Gateway cobranca (Sprint 7 homolog / Sprint 10 HTTP real)
GATEWAY_BASE_URL=https://sandbox.gateway.exeq.local
GATEWAY_MOCK=true
GATEWAY_SYNC_PROCESSING=false

# Rate limit (alinhado legado — auth 10 req/min por IP)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_AUTH=10
# Homolog gateway HTTP (TI): copiar .env.homolog.gateway.example — ver docs/runbooks/RUNBOOK_GATEWAY_TI.md

# Merge DAS — guias DAS/DARF (Fase 1)
FISCAL_DAS_ENABLED=true
RECEITA_DAS_MOCK=true
RECEITA_GATEWAY_PROVIDER=mock
# RECEITA_DAS_CAPTURE_URL=http://127.0.0.1:19443
