# Homolog Betha Cloud — Atibaia DPS (S1-10)

BETHA_INTEGRATION_MODE=dps
BETHA_WSDL_URL=https://nota-eletronica.betha.cloud/dps/ws/service.wsdl
BETHA_WS_URL=https://nota-eletronica.betha.cloud/dps/ws

# OBRIGATÓRIO alinhar com portal Betha (Configurações/Perfil):
#   homolog no portal → homolog + tpAmb 2
#   produção no portal → producao + tpAmb 1
BETHA_PORTAL_AMBIENTE=homolog
BETHA_DPS_TP_AMB=2

BETHA_MOCK=false
HOMOLOG_TEST_AMOUNT_CENTS=100
