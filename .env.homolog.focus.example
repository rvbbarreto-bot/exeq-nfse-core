# Perfil homologação Focus NFe — copiar para .env.local (NUNCA commitar)
# Usado por: ensure-homolog-emission-data.mjs

HOMOLOG_TENANT_SLUG=piloto-sp

# Prestador REAL — deve coincidir com CNPJ cadastrado na Focus homologação
HOMOLOG_PROVIDER_CNPJ=00000000000000
HOMOLOG_PROVIDER_LEGAL_NAME=Razao Social LTDA
HOMOLOG_PROVIDER_MUNICIPAL_REGISTRATION=12345
HOMOLOG_PROVIDER_TAX_REGIME=simples_nacional

# Tomador de teste (homologação NFS-e Nacional)
# CPF fictício (52998224725) gera rejeição E0207 no portal nacional — use CNPJ ativo na RF.
# Padrão: mesmo CNPJ do prestador (B2B homolog) ou outro CNPJ real cadastrado na Focus.
HOMOLOG_CUSTOMER_DOCUMENT=
HOMOLOG_CUSTOMER_NAME=Tomador Homologacao PJ
HOMOLOG_CUSTOMER_IBGE=3504107

# Serviço padrão piloto
HOMOLOG_SERVICE_CODE=1.01
HOMOLOG_SERVICE_DESCRIPTION=Analise e desenvolvimento de sistemas

# Token Focus — preferir npm run homolog:focus:save-token (não colocar aqui se possível)
# FOCUS_TOKEN=
