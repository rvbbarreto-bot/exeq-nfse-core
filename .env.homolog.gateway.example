# Perfil homolog — gateway HTTP real (Sprint 14)
# Copie trechos para exeq-nfse-core/.env (NÃO commitar chaves reais).
# Ver: docs/runbooks/RUNBOOK_GATEWAY_TI.md

PORT=3002
NODE_ENV=development

# Piloto homolog
GATEWAY_BASE_URL=https://sandbox.gateway.exeq.local
GATEWAY_MOCK=false
GATEWAY_SYNC_PROCESSING=true

# Dev/CI mantém mock (não usar este arquivo no validate/E2E):
# GATEWAY_MOCK=true
# GATEWAY_SYNC_PROCESSING=true

# Vault: rotacionar gateway_key antes do smoke
# node scripts/rotate-tenant-secret.mjs --tenant-slug piloto-sp --kind gateway_key --value "<chave-ti>"

# Smoke HTTP (API rodando):
# GATEWAY_MOCK=false GATEWAY_SYNC_PROCESSING=true npm run homolog:gateway-smoke
# Handoff completo: npm run homolog:handoff:full
