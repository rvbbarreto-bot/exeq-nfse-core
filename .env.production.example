# Produção — copiar para secret manager / .env no servidor (NUNCA commitar valores reais)

# Database
DATABASE_URL=postgres://exeq_app:***@db-host:5432/exeq_nfse
MIGRATION_DATABASE_URL=postgres://exeq:***@db-host:5432/exeq_nfse

# Auth
JWT_SECRET=<gerar-min-32-chars-aleatorio>
JWT_EXPIRES_IN=8h

# Secret vault encryption (64 hex chars = 32 bytes)
MASTER_KEY=<64-hex-chars>

# API
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# Não usar seed em produção após setup inicial
# SEED_ADMIN_EMAIL=
# SEED_ADMIN_PASSWORD=

# Redis / workers — OBRIGATÓRIO em produção
REDIS_URL=redis://:***@redis-host:6379
NF_SYNC_PROCESSING=false
WEBHOOK_SYNC_PROCESSING=false

# Focus NFe PRODUÇÃO
FOCUS_BASE_URL=https://api.focusnfe.com.br
FOCUS_MOCK=false
FOCUS_HOMOLOG_MOCK=false
