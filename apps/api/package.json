{
  "name": "@exeq/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:phase9": "vitest run tests/phase9.system.test.ts tests/phase9.functional.test.ts",
    "test:phase10": "vitest run tests/phase10.smoke.test.ts",
    "test:sprint8": "vitest run tests/fiscal-barueri-rascunho.test.ts",
    "test:fiscal-p0-extended": "vitest run tests/fiscal-p0.test.ts tests/fiscal-barueri-rascunho.test.ts tests/fiscal-p0-extended.test.ts",
    "test:sprint10": "vitest run tests/release18.sprint10.gateway.test.ts tests/http-payment-gateway.client.test.ts",
    "test:sprint16": "vitest run tests/sprint16.go-live.test.ts tests/release16.triagem.test.ts tests/release15.hypercare.test.ts",
    "test:sprint17": "vitest run tests/sprint17.operacao-producao.test.ts",
    "test:sprint18": "vitest run tests/sprint18.go-live-suporte.test.ts",
    "test:sprint20": "vitest run tests/sprint20.hypercare-dx.test.ts",
    "test:sprint19": "vitest run tests/sprint19.gateway-producao.test.ts",
    "test:merge-das-fase1": "vitest run tests/merge-das-fase1.test.ts tests/das-receita-gateway.unit.test.ts",
    "test:sprint21": "vitest run tests/sprint21.backfill-snapshots.test.ts",
    "test:sprint15-prep": "vitest run tests/sprint15.prep-5o-municipio.test.ts",
    "test:sprint15": "vitest run tests/sprint15.5o-municipio.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --exclude tests/**",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "worker": "tsx src/worker.ts",
    "smoke:prod": "node ../../scripts/smoke-prod.mjs"
  },
  "dependencies": {
    "@exeq/fiscal-engine": "*",
    "@exeq/shared": "*",
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^9.1.0",
    "@xmldom/xmldom": "^0.9.10",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.52.2",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.43.1",
    "fastify": "^5.3.3",
    "ioredis": "^5.6.1",
    "node-forge": "^1.4.0",
    "postgres": "^3.4.5",
    "xml-crypto": "^6.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.21",
    "@types/node-forge": "^1.3.14",
    "@vitest/coverage-v8": "^3.1.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
